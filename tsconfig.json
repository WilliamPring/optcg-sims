{
  "compilerOptions": {
    // Module system
    "module": "nodenext",
    "target": "esnext",

    // File layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Type-check only; no JS output during development.
    // Remove this (or use tsc --noEmit false) to emit to dist/.
    "noEmit": true,

    // Strictness
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
